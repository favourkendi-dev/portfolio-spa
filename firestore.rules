rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserOrOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProjectOwner(projectUserId) {
      return isAuthenticated() && request.auth.uid == projectUserId;
    }

    function hasProjectRequiredFields() {
      return request.resource.data.keys().hasAll(['title', 'description', 'image', 'userId', 'createdAt']);
    }

    function projectFieldTypesValid() {
      let data = request.resource.data;
      return (
        data.title is string &&
        data.description is string &&
        data.image is string &&
        data.userId is string &&
        (data.url == null || data.url is string) &&
        data.createdAt is string
      );
    }

    function projectFieldLengthsValid() {
      let data = request.resource.data;
      return (
        data.title.size() > 0 && data.title.size() <= 200 &&
        data.description.size() > 0 && data.description.size() <= 2000 &&
        data.image.size() > 0 &&
        data.userId.size() > 0
      );
    }

    function isValidProjectUpdate() {
      let newData = request.resource.data;
      let oldData = resource.data;
      return (
        // Ensure userId and createdAt cannot be changed
        newData.userId == oldData.userId &&
        newData.createdAt == oldData.createdAt &&
        // Validate other fields
        (newData.title is string && newData.title.size() > 0 && newData.title.size() <= 200) &&
        (newData.description is string && newData.description.size() > 0 && newData.description.size() <= 2000) &&
        (newData.image is string && newData.image.size() > 0)
      );
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isUserOrOwner(userId);
    }

    // Projects collection - public read, authenticated write
    match /projects/{projectId} {
      // Allow anyone to read projects
      allow read: if true;

      // Allow authenticated users to create projects
      allow create: if 
        isAuthenticated() &&
        hasProjectRequiredFields() &&
        projectFieldTypesValid() &&
        projectFieldLengthsValid() &&
        isUserOrOwner(request.resource.data.userId);

      // Allow project owners to update their projects
      allow update: if
        isAuthenticated() &&
        isProjectOwner(resource.data.userId) &&
        isValidProjectUpdate();

      // Allow project owners to delete their projects
      allow delete: if
        isAuthenticated() &&
        isProjectOwner(resource.data.userId);
    }

    // Bookmarks collection - user-specific
    match /bookmarks/{bookmarkId} {
      allow read: if 
        isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if 
        isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if 
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if 
        isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Catch-all: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}